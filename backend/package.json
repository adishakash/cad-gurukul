  "description": "CAD Gurukul – AI Career Guidance Platform API",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "start:prod": "prisma generate && prisma migrate deploy && node src/server.js",
