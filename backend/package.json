    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "lint": "eslint src/",
    "email:test": "node scripts/send-test-email.js",
    "smoke:frontend": "node scripts/smoke-frontend-funnel.js",
    "smoke:frontend:deployed": "node scripts/smoke-frontend-deployed.js",
    "smoke:api:deployed": "node scripts/smoke-api-deployed.js",
    "test": "jest --detectOpenHandles"
  },
  "dependencies": {
    "@google/generative-ai": "^0.12.0",
    "@prisma/client": "^5.11.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.12",
    "openai": "^4.38.0",
    "prisma": "^5.11.0",
    "puppeteer": "^22.6.2",
    "razorpay": "^2.9.2",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
