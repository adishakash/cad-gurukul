# ─── Server ───────────────────────────────
NODE_ENV=development
PORT=5000
# Single default frontend origin (fallback when FRONTEND_URLS is not set)
FRONTEND_URL=http://localhost:3000
# Comma-separated allowed origins for backend CORS
# Example: https://cadgurukul.com,https://www.cadgurukul.com,https://app.cadgurukul.com
FRONTEND_URLS=http://localhost:3000
ALLOW_DO_PREVIEW_ORIGINS=true

# ─── Database ─────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/cad_gurukul?schema=public"

# ─── JWT ─────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── OpenAI ──────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# ─── Google Gemini ────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# ─── AI Routing ──────────────────────────
# "openai" | "gemini" | "auto" (auto uses cost-optimized routing)
AI_DEFAULT_PROVIDER=auto

# ─── Razorpay ────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ─── Email ───────────────────────────────
# Titan example:
# SMTP_HOST=smtp.titan.email
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=contact@cadgurukul.com
# SMTP_PASS=your_titan_password
# EMAIL_FROM="CAD Gurukul <contact@cadgurukul.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="CAD Gurukul <noreply@cadgurukul.com>"
EMAIL_REPLY_TO="CAD Gurukul <noreply@cadgurukul.com>"
EMAIL_VERIFY_ON_STARTUP=true
SMTP_CONNECTION_TIMEOUT_MS=20000
SMTP_GREETING_TIMEOUT_MS=20000
SMTP_SOCKET_TIMEOUT_MS=30000

# ─── Consultation Automation ─────────────────────────────
ENABLE_CONSULTATION_AUTOMATION=true
CONSULTATION_AUTOMATION_INTERVAL_MS=300000

# ─── Puppeteer ───────────────────────────
PUPPETEER_EXECUTABLE_PATH=
CHROME_HEADLESS=true

# ─── WhatsApp (optional — omit or set WHATSAPP_PROVIDER=stub for dev) ─────────
# Supported providers: wati | interakt | stub
WHATSAPP_PROVIDER=stub
WHATSAPP_API_URL=https://live-mt-server.wati.io
WHATSAPP_API_TOKEN=your_bearer_token_here

# ─── Rate Limiting ───────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=20

# ─── Logs ────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/app.log
