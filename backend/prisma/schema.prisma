// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  // ── Existing roles (kept for backward compatibility) ──
  STUDENT
  PARENT
  COUNSELLOR

  // ── New hierarchical roles ──────────────────────────
  // Phase 1: ADMIN login is implemented now.
  // CAREER_COUNSELLOR_LEAD and CAREER_COUNSELLOR are schema-ready
  // but their login/endpoints are NOT implemented yet (Phase 2+).
  ADMIN
  CAREER_COUNSELLOR_LEAD
  CAREER_COUNSELLOR
}

enum Board {
  CBSE
  ICSE
  STATE_BOARD
  IGCSE
  IB
  OTHER
}

enum ClassStandard {
  CLASS_8
  CLASS_9
  CLASS_10
  CLASS_11
  CLASS_12
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  FAILED
}

enum QuestionType {
  MCQ
  RATING_SCALE
  OPEN_TEXT
  RANKING
  YES_NO
}

enum QuestionCategory {
  APTITUDE
  PERSONALITY
  INTERESTS
  LEARNING_STYLE
  LOGICAL_REASONING
  CREATIVE_INCLINATION
  SOCIAL_ORIENTATION
  STEM_NON_STEM
  VOCATIONAL_ACADEMIC
}

enum ReportAccessLevel {
  FREE
  PAID
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum PaymentProvider {
  RAZORPAY
}

enum AIProvider {
  OPENAI
  GEMINI
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(STUDENT)

  // Display name — required for ADMIN/COUNSELLOR roles;
  // optional for STUDENT/PARENT (they use StudentProfile.fullName).
  name String?

  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  studentProfile  StudentProfile?
  parentDetails   ParentDetail[]
  assessments     Assessment[]
  payments        Payment[]
  reportDownloads ReportDownload[]
  activityLogs    ActivityLog[]
  aiSessions      AISession[]
  refreshTokens   RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  leads           Lead[]           @relation("LeadOwner")
  assignedLeads   Lead[]           @relation("AssignedLeads")

  // CCL business layer relations
  cclJoiningLinks    CclJoiningLink[]    @relation("CclJoiningLinks")
  cclAttributedSales CclAttributedSale[] @relation("CclAttributedSales")
  cclCommissions     CclCommission[]     @relation("CclCommissions")
  cclPayouts         CclPayout[]         @relation("CclPayouts")
  cclDiscount        CclDiscount?        @relation("CclDiscount")

  // CC business layer relations
  ccTestLinks       CcTestLink[]       @relation("CcTestLinks")
  ccAttributedSales CcAttributedSale[] @relation("CcAttributedSales")
  ccCommissions     CcCommission[]     @relation("CcCommissions")
  ccPayouts         CcPayout[]         @relation("CcPayouts")
  ccDiscount        CcDiscount?        @relation("CcDiscount")
  ccCoupons         CcCoupon[]         @relation("CcCoupons")

  // Partner approval & bank
  isApproved         Boolean             @default(false)
  approvedAt         DateTime?
  suspendedAt        DateTime?
  // Consultation authorization (₹9,999 plan)
  isConsultationAuthorized Boolean       @default(false)
  consultationAuthorizedAt DateTime?
  // CC referral link
  ccReferralCode     String?             @unique
  partnerApplication PartnerApplication?
  bankAccount        BankAccount?

  // Consultation booking (one per ₹9,999 session purchase)
  consultationBookings ConsultationBooking[] @relation("StudentConsultations")
  counsellorConsultationBookings ConsultationBooking[] @relation("CounsellorConsultations")

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

/// One-time email verification token.
/// Created at registration (or resend); deleted on successful verification.
model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("email_verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// STUDENT PROFILE
// ─────────────────────────────────────────────────────────────────────────────

model StudentProfile {
  id                 String         @id @default(cuid())
  userId             String         @unique
  fullName           String
  age                Int?
  classStandard      ClassStandard?
  schoolName         String?
  board              Board?
  city               String?
  state              String?
  pinCode            String?
  mobileNumber       String?
  address            String?
  languagePreference String?        @default("English")

  // Academic
  academicScores    Json? // { subject: score } format
  preferredSubjects String[] @default([])

  // Interests & Personality
  hobbies           String[] @default([])
  interests         String[] @default([])
  careerAspirations String?

  // Higher Education Preferences
  budgetPreference   String? // "under-5L", "5-10L", "10-20L", "20L+"
  locationPreference String[] @default([]) // ["local", "state", "national", "abroad"]

  // Flags
  isOnboardingComplete Boolean @default(false)
  specialNotes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentDetail ParentDetail?

  @@index([userId])
  @@map("student_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARENT DETAILS
// ─────────────────────────────────────────────────────────────────────────────

model ParentDetail {
  id               String  @id @default(cuid())
  userId           String
  studentProfileId String  @unique
  parentName       String
  relationship     String  @default("Parent")
  contactNumber    String?
  email            String?
  occupation       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("parent_details")
}

// ─────────────────────────────────────────────────────────────────────────────
// ASSESSMENTS
// ─────────────────────────────────────────────────────────────────────────────

model Assessment {
  id             String            @id @default(cuid())
  userId         String
  accessLevel    ReportAccessLevel @default(FREE)
  status         AssessmentStatus  @default(IN_PROGRESS)
  currentStep    Int               @default(0)
  totalQuestions Int               @default(0)
  startedAt      DateTime          @default(now())
  completedAt    DateTime?
  metadata       Json? // Additional session context

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions AssessmentQuestion[]
  answers   AssessmentAnswer[]
  report    CareerReport?

  @@index([userId])
  @@index([status])
  @@map("assessments")
}

model AssessmentQuestion {
  id           String           @id @default(cuid())
  assessmentId String
  sequence     Int
  questionText String
  questionType QuestionType
  category     QuestionCategory
  options      Json? // For MCQ: [{label, value}]
  metadata     Json? // Extra AI context
  aiProvider   AIProvider
  generatedAt  DateTime         @default(now())

  assessment Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answer     AssessmentAnswer?

  @@index([assessmentId])
  @@map("assessment_questions")
}

model AssessmentAnswer {
  id           String   @id @default(cuid())
  assessmentId String
  questionId   String   @unique
  answerText   String?
  answerValue  Json? // Structured answer (MCQ choice, rating, etc.)
  timeSpentSec Int? // Time taken to answer
  answeredAt   DateTime @default(now())

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("assessment_answers")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI SESSIONS
// ─────────────────────────────────────────────────────────────────────────────

model AISession {
  id               String     @id @default(cuid())
  userId           String?
  assessmentId     String?
  provider         AIProvider
  model            String
  purpose          String // "question_gen", "evaluation", "report_gen", etc.
  promptTokens     Int        @default(0)
  completionTokens Int        @default(0)
  totalTokens      Int        @default(0)
  latencyMs        Int?
  success          Boolean    @default(true)
  errorMessage     String?
  requestId        String? // Provider request ID for debugging
  createdAt        DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([assessmentId])
  @@index([createdAt])
  @@map("ai_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAREER REPORTS
// ─────────────────────────────────────────────────────────────────────────────

model CareerReport {
  id           String            @id @default(cuid())
  assessmentId String            @unique
  userId       String
  accessLevel  ReportAccessLevel @default(FREE)
  status       ReportStatus      @default(PENDING)

  // Report Content (stored as JSON for flexibility)
  reportData Json? // Full structured report

  // Report tier
  reportType String @default("standard") // "standard" (₹499) | "premium" (₹1,999)

  // Key Scores (indexed for analytics)
  confidenceScore Float? // 0-100
  stemScore       Float?
  creativeScore   Float?
  socialScore     Float?

  // Recommendations (quick-access fields)
  topCareers          String[]
  recommendedStream   String?
  recommendedSubjects String[]
  reportEmailSentAt   DateTime?
  parentEmailSentAt   DateTime?
  emailDeliveryError  String?

  generatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assessment      Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  payment         Payment?
  reportDownloads ReportDownload[]

  @@index([userId])
  @@index([accessLevel])
  @@map("career_reports")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id          String          @id @default(cuid())
  userId      String
  reportId    String?         @unique
  provider    PaymentProvider @default(RAZORPAY)
  amountPaise Int // Amount in smallest unit (paise)
  currency    String          @default("INR")
  status      PaymentStatus   @default(CREATED)

  // Razorpay specific
  razorpayOrderId   String  @unique
  razorpayPaymentId String?
  razorpaySignature String?

  metadata  Json? // Extra payment context
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  report CareerReport? @relation(fields: [reportId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([razorpayOrderId])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPORT DOWNLOADS
// ─────────────────────────────────────────────────────────────────────────────

model ReportDownload {
  id        String   @id @default(cuid())
  reportId  String
  userId    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  report CareerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([userId])
  @@map("report_downloads")
}

// ─────────────────────────────────────────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activityLogs ActivityLog[]

  @@index([email])
  @@map("admin_users")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRICING PLANS
// ─────────────────────────────────────────────────────────────────────────────

model PricingPlan {
  id           String            @id @default(cuid())
  name         String
  accessLevel  ReportAccessLevel
  amountPaise  Int
  currency     String            @default("INR")
  features     String[]
  isActive     Boolean           @default(true)
  displayOrder Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@map("pricing_plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITY LOGS
// ─────────────────────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  adminUserId String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([adminUserId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTACT QUERIES
// ─────────────────────────────────────────────────────────────────────────────

model ContactQuery {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("contact_queries")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEADS (conversion funnel tracking)
// ─────────────────────────────────────────────────────────────────────────────

enum LeadStatus {
  new_lead
  onboarding_started
  plan_selected
  assessment_started
  assessment_in_progress
  assessment_completed
  free_report_ready
  payment_pending
  paid
  premium_report_generating
  premium_report_ready
  counselling_interested
  closed
}

enum LeadSource {
  meta_ads
  instagram
  facebook
  google_ads
  direct
  referral
  organic
  whatsapp
  other
}

enum UserType {
  student
  parent
}

model Lead {
  id            String     @id @default(cuid())
  userId        String? // nullable — lead may exist before account creation
  fullName      String
  email         String
  mobileNumber  String
  classStandard String? // "8","9","10","11","12"
  stream        String? // "Science","Commerce","Arts","Not Decided"
  city          String?
  pincode       String?
  userType      UserType   @default(student)
  selectedPlan  String     @default("free") // "free" | "paid"
  status        LeadStatus @default(new_lead)

  // UTM / attribution
  leadSource   LeadSource @default(direct)
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  referralCode String?

  // Value ladder tracking
  planType           String? @default("standard") // "standard" | "premium" | "consultation"
  qualificationScore Int?    @default(0) // 0-100; gates ₹9,999 session offer

  // Counselling flag
  counsellingInterested Boolean @default(false)
  counsellingNotes      String?

  // Linked entities (set as funnel progresses)
  assessmentId String?
  reportId     String?
  paymentId    String?

  // Lead assignment (Phase Admin-v2)
  assignedStaffId String? // FK to User (CC or CCL)
  assignedAt      DateTime? // when the assignment was made
  assignedBy      String? // adminUser.id who made the assignment

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                 User?                 @relation("LeadOwner", fields: [userId], references: [id], onDelete: SetNull)
  assignedStaff        User?                 @relation("AssignedLeads", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  events               LeadEvent[]
  consultationBookings ConsultationBooking[]

  @@unique([email])
  @@index([mobileNumber])
  @@index([status])
  @@index([leadSource])
  @@index([createdAt])
  @@index([userId])
  @@index([assignedStaffId])
  @@map("leads")
}

model LeadEvent {
  id        String   @id @default(cuid())
  leadId    String
  event     String // e.g. "assessment_started", "payment_success"
  metadata  Json? // any extra context
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([event])
  @@index([createdAt])
  @@map("lead_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// WHATSAPP MESSAGES (log for audit + retry)
// ─────────────────────────────────────────────────────────────────────────────

enum WhatsAppStatus {
  queued
  sent
  delivered
  failed
  skipped
}

model WhatsAppMessage {
  id           String         @id @default(cuid())
  leadId       String?
  userId       String?
  toNumber     String
  templateName String
  payload      Json // template variables
  status       WhatsAppStatus @default(queued)
  providerRef  String? // provider message ID for tracking
  errorMessage String?
  retryCount   Int            @default(0)
  sentAt       DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([leadId])
  @@index([status])
  @@index([toNumber])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTOMATION JOBS (event-driven async tasks)
// ─────────────────────────────────────────────────────────────────────────────

enum AutomationJobStatus {
  pending
  processing
  done
  failed
  skipped
}

model AutomationJob {
  id          String              @id @default(cuid())
  eventName   String // e.g. "payment_success", "assessment_completed"
  payload     Json // event payload
  status      AutomationJobStatus @default(pending)
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(3)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([eventName])
  @@index([status])
  @@index([createdAt])
  @@map("automation_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ANALYTICS EVENTS (lightweight funnel tracking)
// ─────────────────────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(cuid())
  event     String // e.g. "lead_created", "premium_cta_clicked"
  userId    String?
  leadId    String?
  sessionId String?
  source    String? // utm_source or lead source
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([leadId])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// CCL BUSINESS LAYER — Phase 4
// ─────────────────────────────────────────────────────────────────────────────

/// Joining links created by a CCL to onboard new counsellor candidates.
/// Each link carries a unique code; clicking it starts the ₹12,000 joining flow
/// and attributes the sale back to the originating CCL.
model CclJoiningLink {
  id        String @id @default(cuid())
  cclUserId String
  code      String @unique

  candidateName  String?
  candidateEmail String?
  candidatePhone String?

  feeAmountPaise Int @default(1200000) // ₹12,000

  // Inline discount applied when this link was created (Phase 6)
  discountPctUsed Float @default(0)

  // Payment tracking for the candidate's joining payment
  joiningOrderId        String? @unique // Razorpay order ID created for this link
  joiningPaymentId      String? // Razorpay payment ID after capture
  joiningPaymentStatus  String  @default("pending") // "pending" | "initiated" | "captured" | "failed"
  joiningNetAmountPaise Int? // Effective amount after discount (stored at order creation)

  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cclUser        User               @relation("CclJoiningLinks", fields: [cclUserId], references: [id], onDelete: Cascade)
  attributedSale CclAttributedSale?

  @@index([cclUserId])
  @@index([code])
  @@index([joiningOrderId])
  @@map("ccl_joining_links")
}

/// Ledger record for every sale attributed to a CCL — whether via joining link
/// or referral code. Commission is always 10% of netAmountPaise.
model CclAttributedSale {
  id            String  @id @default(cuid())
  cclUserId     String
  joiningLinkId String? @unique // populated for joining-link sales
  paymentId     String? @unique // FK to platform Payment row, if available
  saleType      String // "joining" | "referral" | "other"

  grossAmountPaise    Int
  discountAmountPaise Int @default(0)
  netAmountPaise      Int
  commissionPaise     Int // 10% of netAmountPaise

  status String @default("pending") // "pending" | "confirmed" | "refunded"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cclUser     User            @relation("CclAttributedSales", fields: [cclUserId], references: [id])
  joiningLink CclJoiningLink? @relation(fields: [joiningLinkId], references: [id])
  commission  CclCommission?

  @@index([cclUserId])
  @@index([status])
  @@map("ccl_attributed_sales")
}

/// One commission record per attributed sale. Aggregated into a CclPayout when
/// the weekly Thursday transfer is processed.
model CclCommission {
  id               String @id @default(cuid())
  cclUserId        String
  attributedSaleId String @unique
  amountPaise      Int

  status   String  @default("pending") // "pending" | "paid" | "cancelled"
  payoutId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cclUser        User              @relation("CclCommissions", fields: [cclUserId], references: [id])
  attributedSale CclAttributedSale @relation(fields: [attributedSaleId], references: [id])
  payout         CclPayout?        @relation(fields: [payoutId], references: [id])

  @@index([cclUserId])
  @@index([status])
  @@map("ccl_commissions")
}

/// Weekly payout record — one per CCL per Thursday cycle. Groups commissions.
model CclPayout {
  id                  String    @id @default(cuid())
  cclUserId           String
  amountPaise         Int
  status              String    @default("pending") // "pending" | "processing" | "paid" | "failed"
  scheduledFor        DateTime // always a Thursday
  processedAt         DateTime?
  reference           String? // bank transfer reference once paid
  notes               String?
  failureCount        Int       @default(0) // consecutive failure count
  isFlagged           Boolean   @default(false)
  bankAccountSnapshot Json? // snapshot of bank details at transfer time
  transferInitiatedAt DateTime?
  transferRef         String? // Razorpay Payout ID or NEFT ref

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cclUser     User            @relation("CclPayouts", fields: [cclUserId], references: [id])
  commissions CclCommission[]

  @@index([cclUserId])
  @@index([status])
  @@index([scheduledFor])
  @@map("ccl_payouts")
}

/// Optional per-CCL discount configuration. Cap enforced at 20% in the backend.
model CclDiscount {
  id          String   @id @default(cuid())
  cclUserId   String   @unique
  discountPct Float    @default(0) // 0–20
  isActive    Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  cclUser User @relation("CclDiscount", fields: [cclUserId], references: [id], onDelete: Cascade)

  @@map("ccl_discounts")
}

/// Training content items visible to CCL (videos, books, documents).
/// Managed by Admin; read-only for CCL.
/// targetRole controls which role sees this content: 'CCL', 'CC', or 'ALL'.
model CclTrainingContent {
  id           String  @id @default(cuid())
  title        String
  type         String // "video" | "book" | "document"
  url          String?
  description  String?
  isActive     Boolean @default(true)
  displayOrder Int     @default(0)
  targetRole   String  @default("CCL") // "CCL" | "CC" | "ALL"

  // Phase 6: file upload support
  originalFilename String? // original file name — NOT exposed to staff
  storagePath      String? // internal storage path/key
  isDownloadable   Boolean @default(false)
  mimeType         String?

  // Soft delete / history (Phase Admin-v2)
  deletedAt DateTime?
  deletedBy String? // adminUser.id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
  @@map("ccl_training_content")
}

// ─────────────────────────────────────────────────────────────────────────────
// CC BUSINESS LAYER — Phase 5
// ─────────────────────────────────────────────────────────────────────────────

/// Test links created by a CC to send to students/parents.
/// Payment goes to platform; successful payment creates CcAttributedSale + CcCommission.
model CcTestLink {
  id                 String    @id @default(cuid())
  ccUserId           String
  code               String    @unique
  planType           String    @default("standard") // "499plan" | "standard"
  candidateName      String?
  candidateEmail     String?
  candidatePhone     String?
  feeAmountPaise     Int       @default(49900) // ₹499
  isUsed             Boolean   @default(false)
  usedAt             DateTime?
  expiresAt          DateTime?
  testOrderId        String?   @unique
  testPaymentId      String?
  testPaymentStatus  String    @default("pending")
  testNetAmountPaise Int?
  // Phase 6: inline discount applied when this link was created
  discountPctUsed    Float     @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  ccUser          User               @relation("CcTestLinks", fields: [ccUserId], references: [id], onDelete: Cascade)
  attributedSales CcAttributedSale[]

  @@index([ccUserId])
  @@index([testOrderId])
  @@map("cc_test_links")
}

/// Ledger record for every sale attributed to a CC via test link. Commission is 70% of netAmountPaise.
model CcAttributedSale {
  id                  String   @id @default(cuid())
  ccUserId            String
  testLinkId          String?  @unique
  paymentId           String   @unique
  saleType            String
  planType            String   @default("standard")
  grossAmountPaise    Int
  discountAmountPaise Int      @default(0)
  netAmountPaise      Int
  commissionRate      Float    @default(0.7)
  commissionPaise     Int
  ccCouponId          String?
  couponCode          String?
  status              String   @default("confirmed")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  ccUser     User          @relation("CcAttributedSales", fields: [ccUserId], references: [id], onDelete: Restrict)
  testLink   CcTestLink?   @relation(fields: [testLinkId], references: [id], onDelete: SetNull)
  ccCoupon   CcCoupon?     @relation(fields: [ccCouponId], references: [id], onDelete: SetNull)
  commission CcCommission?

  @@index([ccUserId])
  @@index([status])
  @@index([ccCouponId])
  @@map("cc_attributed_sales")
}

/// One commission record per attributed CC sale. Aggregated into CcPayout on Thursday.
model CcCommission {
  id               String   @id @default(cuid())
  ccUserId         String
  attributedSaleId String   @unique
  amountPaise      Int
  status           String   @default("pending") // pending | in_payout | paid | cancelled
  payoutId         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  ccUser         User             @relation("CcCommissions", fields: [ccUserId], references: [id], onDelete: Restrict)
  attributedSale CcAttributedSale @relation(fields: [attributedSaleId], references: [id])
  payout         CcPayout?        @relation(fields: [payoutId], references: [id])

  @@index([ccUserId])
  @@index([status])
  @@map("cc_commissions")
}

/// Weekly payout record — one per CC per Thursday cycle. Groups commissions.
model CcPayout {
  id                  String    @id @default(cuid())
  ccUserId            String
  amountPaise         Int
  status              String    @default("pending")
  scheduledFor        DateTime
  processedAt         DateTime?
  reference           String?
  notes               String?
  failureCount        Int       @default(0)
  isFlagged           Boolean   @default(false)
  bankAccountSnapshot Json?
  transferInitiatedAt DateTime?
  transferRef         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  ccUser      User           @relation("CcPayouts", fields: [ccUserId], references: [id], onDelete: Restrict)
  commissions CcCommission[]

  @@index([ccUserId])
  @@index([status])
  @@index([scheduledFor])
  @@map("cc_payouts")
}

/// Optional per-CC discount configuration. Cap enforced in backend (plan-aware).
model CcDiscount {
  id          String   @id @default(cuid())
  ccUserId    String   @unique
  discountPct Float    @default(0)
  planType    String   @default("standard") // "499plan" | "standard" — determines max cap
  isActive    Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  ccUser User @relation("CcDiscount", fields: [ccUserId], references: [id], onDelete: Cascade)

  @@map("cc_discounts")
}

/// Per-CC discount coupons for standard/premium/consultation plans.
model CcCoupon {
  id             String   @id @default(cuid())
  ccUserId       String
  code           String   @unique
  planType       String   // "standard" | "premium" | "consultation"
  discountPct    Float    @default(0)
  isActive       Boolean  @default(true)
  usageCount     Int      @default(0)
  maxRedemptions Int?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ccUser          User               @relation("CcCoupons", fields: [ccUserId], references: [id], onDelete: Cascade)
  attributedSales CcAttributedSale[]

  @@index([ccUserId])
  @@index([planType])
  @@index([isActive])
  @@map("cc_coupons")
}

// ─────────────────────────────────────────────────────────────────────────────
// DISCOUNT POLICIES — Phase 6
// ─────────────────────────────────────────────────────────────────────────────

/// Admin-managed discount policy per role+planType.
/// Defines the allowed min/max discount range staff can apply at link creation.
model DiscountPolicy {
  id       String  @id @default(cuid())
  role     String // "CAREER_COUNSELLOR_LEAD" | "CAREER_COUNSELLOR"
  planType String // "joining" | "499plan" | "standard" | "premium" | "consultation"
  minPct   Float   @default(0)
  maxPct   Float   @default(20)
  isActive Boolean @default(true)

  // Soft delete / history
  deletedAt DateTime?
  deletedBy String? // adminUser.id

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([role, planType])
  @@index([deletedAt])
  @@map("discount_policies")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARTNER APPLICATION & APPROVAL — Phase MVP
// ─────────────────────────────────────────────────────────────────────────────

enum ApplicationStatus {
  pending
  approved
  rejected
  suspended
}

/// Tracks the onboarding application for CAREER_COUNSELLOR and CAREER_COUNSELLOR_LEAD.
/// Admin must approve before the partner can log in.
model PartnerApplication {
  id            String            @id @default(cuid())
  userId        String            @unique
  role          UserRole // CAREER_COUNSELLOR | CAREER_COUNSELLOR_LEAD
  status        ApplicationStatus @default(pending)
  fullName      String
  phone         String
  city          String?
  qualification String?
  experience    String?
  addressLine   String?
  pincode       String?
  referredBy    String? // cclUserId who referred this CC candidate
  graduationDocPath String?
  graduationDocName String?
  graduationDocMime String?
  graduationDocSize Int?
  idDocPath     String?
  idDocName     String?
  idDocMime     String?
  idDocSize     Int?
  paymentStatus String           @default("created")
  razorpayOrderId   String?      @unique
  razorpayPaymentId String?
  razorpaySignature String?
  paymentAmountPaise Int?
  discountPct   Float?
  couponCode    String?
  gstRate       Float?
  gstAmountPaise Int?
  taxableAmountPaise Int?
  totalAmountPaise Int?
  paidAt        DateTime?
  adminNotes    String?
  reviewedBy    String? // adminUserId
  reviewedAt    DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([role])
  @@map("partner_applications")
}

// ─────────────────────────────────────────────────────────────────────────────
// COUNSELLOR COUPONS (Join fee discounts)
// ─────────────────────────────────────────────────────────────────────────────

model CounsellorCoupon {
  id         String   @id @default(cuid())
  code       String   @unique
  discountPct Float   @default(0)
  isActive   Boolean  @default(true)
  maxUses    Int?
  usedCount  Int      @default(0)
  startsAt   DateTime?
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@index([expiresAt])
  @@map("counsellor_coupons")
}

// ─────────────────────────────────────────────────────────────────────────────
// BANK ACCOUNTS — Phase MVP
// ─────────────────────────────────────────────────────────────────────────────

/// Partner bank account for payout routing.
/// accountNumberEnc is AES-256-GCM encrypted before storage.
model BankAccount {
  id                 String    @id @default(cuid())
  userId             String    @unique
  accountHolder      String
  accountNumberEnc   String // AES-256-GCM encrypted
  accountNumberLast4 String // last 4 digits for display only
  ifscCode           String
  bankName           String
  accountType        String    @default("savings") // "savings" | "current"
  isVerified         Boolean   @default(false)
  verifiedAt         DateTime?
  verifiedBy         String? // adminUserId
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_accounts")
}

// ─────────────────────────────────────────────────────────────────────────────
// SETTLEMENT SCHEDULE — Phase MVP
// ─────────────────────────────────────────────────────────────────────────────

/// Admin-configurable settlement schedule. One row per role group.
/// isPaused=true blocks the Thursday cron for that role.
model SettlementSchedule {
  id          String    @id @default(cuid())
  role        String    @unique // "CC" | "CCL" | "ALL"
  dayOfWeek   Int       @default(4) // 4 = Thursday (JS Date.getDay())
  isPaused    Boolean   @default(false)
  pausedBy    String? // adminUserId
  pausedAt    DateTime?
  pauseReason String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  @@map("settlement_schedules")
}

// ─────────────────────────────────────────────────────────────────────────────
// COMMISSION ADJUSTMENTS — Phase MVP
// ─────────────────────────────────────────────────────────────────────────────

enum AdjustmentType {
  REFUND_REVERSAL
  PLATFORM_FEE
  MANUAL_CREDIT
  MANUAL_DEBIT
  TAX_DEDUCTION
}

/// Manual or automated correction applied to a partner's earning ledger.
/// Positive amountPaise = credit; negative = debit.
/// Applied in the next payout calculation, never retroactively changes existing CcPayout.
model CommissionAdjustment {
  id           String         @id @default(cuid())
  role         String // "CC" | "CCL"
  partnerId    String // ccUserId or cclUserId
  commissionId String?
  type         AdjustmentType
  amountPaise  Int // positive=credit, negative=debit
  reason       String
  createdBy    String // adminUserId
  createdAt    DateTime       @default(now())

  @@index([partnerId])
  @@index([type])
  @@index([createdAt])
  @@map("commission_adjustments")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYOUT FRAUD FLAG — Phase MVP
// ─────────────────────────────────────────────────────────────────────────────

enum FraudFlagStatus {
  open
  investigating
  cleared
  confirmed_fraud
}

/// Created automatically after 3 consecutive Thursday payout failures for a partner,
/// or manually by Admin. Blocks all payouts for the partner until cleared.
model PayoutFraudFlag {
  id         String          @id @default(cuid())
  role       String // "CC" | "CCL"
  partnerId  String
  payoutId   String?
  reason     String
  status     FraudFlagStatus @default(open)
  resolvedBy String?
  resolvedAt DateTime?
  notes      String?
  createdAt  DateTime        @default(now())

  @@index([partnerId])
  @@index([status])
  @@map("payout_fraud_flags")
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION LOG — Phase MVP
// ─────────────────────────────────────────────────────────────────────────────

enum NotificationChannel {
  whatsapp
  email
  sms
}

/// Partner-facing notification audit log (approval, commission, payout events).
model NotificationLog {
  id          String              @id @default(cuid())
  userId      String
  channel     NotificationChannel
  templateKey String
  payload     Json
  status      WhatsAppStatus      @default(queued)
  sentAt      DateTime?
  errorMsg    String?
  createdAt   DateTime            @default(now())

  @@index([userId])
  @@index([channel])
  @@index([createdAt])
  @@map("notification_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ASSESSMENT PERSONALIZATION — Phase 2
// ─────────────────────────────────────────────────────────────────────────────

/// Deterministic rule sets for selecting question category mix.
/// Evaluated in priority order; first match wins.
model AssessmentProfileRule {
  id                 String   @id @default(cuid())
  name               String
  classMin           Int?
  classMax           Int?
  ageMin             Int?
  ageMax             Int?
  boards             String[] @default([]) // empty = all boards
  streams            String[] @default([]) // empty = all streams
  requiredCategories String[] @default([]) // QuestionCategory values to emphasise
  questionCount      Int      @default(10)
  isActive           Boolean  @default(true)
  priority           Int      @default(0) // higher = evaluated first
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("assessment_profile_rules")
}

/// Reusable question pool. Admin-managed.
model QuestionTemplate {
  id           String           @id @default(cuid())
  questionText String
  questionType QuestionType
  category     QuestionCategory
  options      Json?
  tags         String[]         @default([])
  classMin     Int?
  classMax     Int?
  ageMin       Int?
  ageMax       Int?
  streams      String[]         @default([])
  isActive     Boolean          @default(true)
  usageCount   Int              @default(0)
  createdBy    String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("question_templates")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRICING PLANS — add isPartnerVisible field
// ─────────────────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────────────────
// CONSULTATION BOOKINGS — Phase 7 + Phase 10 (Scheduling & Google Meet)
// ─────────────────────────────────────────────────────────────────────────────

/// Created immediately after a ₹9,999 consultation payment is captured.
/// Tracks the full counselling lifecycle from slot-selection email → meeting completed.
model ConsultationBooking {
  id        String  @id @default(cuid())
  userId    String
  leadId    String? // nullable for backward compat
  paymentId String  @unique // Payment.id — soft reference (no Prisma relation on Payment side)

  /// Assigned counsellor (optional, for partner view)
  counsellorUserId String?

  /// Secure 64-char hex token included in the slot-selection email link.
  /// Used to authenticate the slot selection without requiring the student to log in.
  slotToken String @unique

  /// Counsellor details — can be updated by admin before the session.
  counsellorName      String @default("Adish Gupta")
  counsellorExpertise String @default("Career Guidance Specialist | 10+ years | IIT Alumni")
  counsellorContact   String @default("adish@cadgurukul.com")

  /// Slot selected by the student via email link.
  /// Values: 'morning_9_12' | 'afternoon_2_5' | 'evening_6_9' (legacy)
  /// OR: resolved from AvailabilitySlot (Phase 10 — specific date+time)
  selectedSlot   String?
  slotSelectedAt DateTime?

  /// Exact schedule selected by the student for the live session.
  scheduledStartAt        DateTime? @unique
  scheduledEndAt          DateTime?
  scheduledTimezone       String    @default("Asia/Kolkata")
  meetingProvider         String    @default("JITSI")
  meetingRoomName         String?
  meetingConfirmedAt      DateTime?
  schedulingEmailSentAt   DateTime?
  schedulingEmailError    String?
  reminder24hSentAt       DateTime?
  reminder2hSentAt        DateTime?
  followUpSentAt          DateTime?
  counsellingReportSentAt DateTime?

  /// Booking lifecycle — driven by backend events.
  /// Values: 'booking_confirmed' | 'slot_mail_sent' | 'slot_selected' | 'meeting_scheduled'
  ///        | 'meeting_completed' | 'counselling_report_ready'
  status String @default("booking_confirmed")

  /// Meeting details set externally by the team once a slot is confirmed.
  meetingDate  DateTime?
  meetingLink  String?
  meetingNotes String?

  /// Resend tracking — guards against email spam and lets frontend show cooldown.
  lastResendAt DateTime? // null = email never manually resent
  resendCount  Int       @default(0) // total manual resend count (not counting initial send)

  // ── Phase 10: Date-specific slot + Google Meet ─────────────────────────────

  /// Denormalised date/time fields populated when a date-specific AvailabilitySlot is booked.
  scheduledDate      DateTime?  // specific calendar date of the session
  scheduledStartTime String?    // "09:00" (IST)
  scheduledEndTime   String?    // "12:00" (IST)

  /// Google Calendar/Meet integration — set after Google Calendar event is created.
  googleMeetLink String?  // e.g. https://meet.google.com/xxx-yyyy-zzz
  googleEventId  String?  // Google Calendar event ID for updates/deletions
  meetLinkSentAt DateTime? // timestamp when the meet-link email was dispatched

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation("StudentConsultations", fields: [userId], references: [id], onDelete: Cascade)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  counsellorUser User? @relation("CounsellorConsultations", fields: [counsellorUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([counsellorUserId])
  @@index([slotToken])
  @@index([status])
  @@index([scheduledStartAt])
  @@map("consultation_bookings")
}

/// Admin-managed blocks that make exact consultation dates / times unavailable.
/// If isFullDay=true, the entire local calendar date is hidden from students.
model ConsultationAvailabilityBlock {
  id        String   @id @default(cuid())
  startsAt  DateTime
  endsAt    DateTime
  timezone  String   @default("Asia/Kolkata")
  isFullDay Boolean  @default(false)
  reason    String?
  createdBy String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startsAt, endsAt])
  @@index([isActive])
  @@map("consultation_availability_blocks")
}
