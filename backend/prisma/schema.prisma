// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  // ── Existing roles (kept for backward compatibility) ──
  STUDENT
  PARENT
  COUNSELLOR

  // ── New hierarchical roles ──────────────────────────
  // Phase 1: ADMIN login is implemented now.
  // CAREER_COUNSELLOR_LEAD and CAREER_COUNSELLOR are schema-ready
  // but their login/endpoints are NOT implemented yet (Phase 2+).
  ADMIN
  CAREER_COUNSELLOR_LEAD
  CAREER_COUNSELLOR
}

enum Board {
  CBSE
  ICSE
  STATE_BOARD
  IGCSE
  IB
  OTHER
}

enum ClassStandard {
  CLASS_8
  CLASS_9
  CLASS_10
  CLASS_11
  CLASS_12
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
  FAILED
}

enum QuestionType {
  MCQ
  RATING_SCALE
  OPEN_TEXT
  RANKING
  YES_NO
}

enum QuestionCategory {
  APTITUDE
  PERSONALITY
  INTERESTS
  LEARNING_STYLE
  LOGICAL_REASONING
  CREATIVE_INCLINATION
  SOCIAL_ORIENTATION
  STEM_NON_STEM
  VOCATIONAL_ACADEMIC
}

enum ReportAccessLevel {
  FREE
  PAID
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

enum PaymentStatus {
  CREATED
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum PaymentProvider {
  RAZORPAY
}

enum AIProvider {
  OPENAI
  GEMINI
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

// ─────────────────────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  role            UserRole @default(STUDENT)

  // Display name — required for ADMIN/COUNSELLOR roles;
  // optional for STUDENT/PARENT (they use StudentProfile.fullName).
  name            String?

  isEmailVerified Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  studentProfile  StudentProfile?
  parentDetails   ParentDetail[]
  assessments     Assessment[]
  payments        Payment[]
  reportDownloads ReportDownload[]
  activityLogs    ActivityLog[]
  aiSessions      AISession[]
  refreshTokens   RefreshToken[]
  leads           Lead[]

  // CCL business layer relations
  cclJoiningLinks    CclJoiningLink[]    @relation("CclJoiningLinks")
  cclAttributedSales CclAttributedSale[] @relation("CclAttributedSales")
  cclCommissions     CclCommission[]     @relation("CclCommissions")
  cclPayouts         CclPayout[]         @relation("CclPayouts")
  cclDiscount        CclDiscount?        @relation("CclDiscount")

  // CC business layer relations
  ccTestLinks        CcTestLink[]        @relation("CcTestLinks")
  ccAttributedSales  CcAttributedSale[]  @relation("CcAttributedSales")
  ccCommissions      CcCommission[]      @relation("CcCommissions")
  ccPayouts          CcPayout[]          @relation("CcPayouts")
  ccDiscount         CcDiscount?         @relation("CcDiscount")

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// STUDENT PROFILE
// ─────────────────────────────────────────────────────────────────────────────

model StudentProfile {
  id                String         @id @default(cuid())
  userId            String         @unique
  fullName          String
  age               Int?
  classStandard     ClassStandard?
  schoolName        String?
  board             Board?
  city              String?
  state             String?
  pinCode           String?
  mobileNumber      String?
  address           String?
  languagePreference String?       @default("English")

  // Academic
  academicScores    Json?          // { subject: score } format
  preferredSubjects String[]       @default([])

  // Interests & Personality
  hobbies           String[]       @default([])
  interests         String[]       @default([])
  careerAspirations String?

  // Higher Education Preferences
  budgetPreference  String?        // "under-5L", "5-10L", "10-20L", "20L+"
  locationPreference String[]      @default([]) // ["local", "state", "national", "abroad"]

  // Flags
  isOnboardingComplete Boolean @default(false)
  specialNotes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentDetail ParentDetail?

  @@index([userId])
  @@map("student_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARENT DETAILS
// ─────────────────────────────────────────────────────────────────────────────

model ParentDetail {
  id               String  @id @default(cuid())
  userId           String
  studentProfileId String  @unique
  parentName       String
  relationship     String  @default("Parent")
  contactNumber    String?
  email            String?
  occupation       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentProfile StudentProfile @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("parent_details")
}

// ─────────────────────────────────────────────────────────────────────────────
// ASSESSMENTS
// ─────────────────────────────────────────────────────────────────────────────

model Assessment {
  id             String           @id @default(cuid())
  userId         String
  accessLevel    ReportAccessLevel @default(FREE)
  status         AssessmentStatus  @default(IN_PROGRESS)
  currentStep    Int               @default(0)
  totalQuestions Int               @default(0)
  startedAt      DateTime          @default(now())
  completedAt    DateTime?
  metadata       Json?             // Additional session context

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions AssessmentQuestion[]
  answers   AssessmentAnswer[]
  report    CareerReport?

  @@index([userId])
  @@index([status])
  @@map("assessments")
}

model AssessmentQuestion {
  id           String           @id @default(cuid())
  assessmentId String
  sequence     Int
  questionText String
  questionType QuestionType
  category     QuestionCategory
  options      Json?            // For MCQ: [{label, value}]
  metadata     Json?            // Extra AI context
  aiProvider   AIProvider
  generatedAt  DateTime         @default(now())

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  answer     AssessmentAnswer?

  @@index([assessmentId])
  @@map("assessment_questions")
}

model AssessmentAnswer {
  id           String   @id @default(cuid())
  assessmentId String
  questionId   String   @unique
  answerText   String?
  answerValue  Json?    // Structured answer (MCQ choice, rating, etc.)
  timeSpentSec Int?     // Time taken to answer
  answeredAt   DateTime @default(now())

  assessment Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@map("assessment_answers")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI SESSIONS
// ─────────────────────────────────────────────────────────────────────────────

model AISession {
  id           String     @id @default(cuid())
  userId       String?
  assessmentId String?
  provider     AIProvider
  model        String
  purpose      String     // "question_gen", "evaluation", "report_gen", etc.
  promptTokens Int        @default(0)
  completionTokens Int    @default(0)
  totalTokens  Int        @default(0)
  latencyMs    Int?
  success      Boolean    @default(true)
  errorMessage String?
  requestId    String?    // Provider request ID for debugging
  createdAt    DateTime   @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([assessmentId])
  @@index([createdAt])
  @@map("ai_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// CAREER REPORTS
// ─────────────────────────────────────────────────────────────────────────────

model CareerReport {
  id           String            @id @default(cuid())
  assessmentId String            @unique
  userId       String
  accessLevel  ReportAccessLevel @default(FREE)
  status       ReportStatus      @default(PENDING)

  // Report Content (stored as JSON for flexibility)
  reportData   Json?             // Full structured report

  // Report tier
  reportType   String  @default("standard")  // "standard" (₹499) | "premium" (₹1,999)

  // Key Scores (indexed for analytics)
  confidenceScore Float?         // 0-100
  stemScore       Float?
  creativeScore   Float?
  socialScore     Float?

  // Recommendations (quick-access fields)
  topCareers      String[]
  recommendedStream String?
  recommendedSubjects String[]

  generatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assessment      Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  payment         Payment?
  reportDownloads ReportDownload[]

  @@index([userId])
  @@index([accessLevel])
  @@map("career_reports")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id               String          @id @default(cuid())
  userId           String
  reportId         String?         @unique
  provider         PaymentProvider @default(RAZORPAY)
  amountPaise      Int             // Amount in smallest unit (paise)
  currency         String          @default("INR")
  status           PaymentStatus   @default(CREATED)

  // Razorpay specific
  razorpayOrderId  String          @unique
  razorpayPaymentId String?
  razorpaySignature String?

  metadata         Json?           // Extra payment context
  paidAt           DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  report CareerReport? @relation(fields: [reportId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([razorpayOrderId])
  @@map("payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPORT DOWNLOADS
// ─────────────────────────────────────────────────────────────────────────────

model ReportDownload {
  id        String   @id @default(cuid())
  reportId  String
  userId    String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  report CareerReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([userId])
  @@map("report_downloads")
}

// ─────────────────────────────────────────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activityLogs ActivityLog[]

  @@index([email])
  @@map("admin_users")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRICING PLANS
// ─────────────────────────────────────────────────────────────────────────────

model PricingPlan {
  id           String            @id @default(cuid())
  name         String
  accessLevel  ReportAccessLevel
  amountPaise  Int
  currency     String            @default("INR")
  features     String[]
  isActive     Boolean           @default(true)
  displayOrder Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@map("pricing_plans")
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIVITY LOGS
// ─────────────────────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  adminUserId String?
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([adminUserId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// CONTACT QUERIES
// ─────────────────────────────────────────────────────────────────────────────

model ContactQuery {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
  @@map("contact_queries")
}

// ─────────────────────────────────────────────────────────────────────────────
// LEADS (conversion funnel tracking)
// ─────────────────────────────────────────────────────────────────────────────

enum LeadStatus {
  new_lead
  onboarding_started
  plan_selected
  assessment_started
  assessment_in_progress
  assessment_completed
  free_report_ready
  payment_pending
  paid
  premium_report_generating
  premium_report_ready
  counselling_interested
  closed
}

enum LeadSource {
  meta_ads
  instagram
  facebook
  google_ads
  direct
  referral
  organic
  whatsapp
  other
}

enum UserType {
  student
  parent
}

model Lead {
  id             String     @id @default(cuid())
  userId         String?    // nullable — lead may exist before account creation
  fullName       String
  email          String
  mobileNumber   String
  classStandard  String?    // "8","9","10","11","12"
  stream         String?    // "Science","Commerce","Arts","Not Decided"
  city           String?
  pincode        String?
  userType       UserType   @default(student)
  selectedPlan   String     @default("free") // "free" | "paid"
  status         LeadStatus @default(new_lead)

  // UTM / attribution
  leadSource     LeadSource @default(direct)
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  referralCode   String?

  // Value ladder tracking
  planType              String?  @default("standard") // "standard" | "premium" | "consultation"
  qualificationScore    Int?     @default(0)           // 0-100; gates ₹9,999 session offer

  // Counselling flag
  counsellingInterested Boolean @default(false)
  counsellingNotes      String?

  // Linked entities (set as funnel progresses)
  assessmentId   String?
  reportId       String?
  paymentId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  events  LeadEvent[]

  @@unique([email])
  @@index([mobileNumber])
  @@index([status])
  @@index([leadSource])
  @@index([createdAt])
  @@index([userId])
  @@map("leads")
}

model LeadEvent {
  id        String   @id @default(cuid())
  leadId    String
  event     String   // e.g. "assessment_started", "payment_success"
  metadata  Json?    // any extra context
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([event])
  @@index([createdAt])
  @@map("lead_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// WHATSAPP MESSAGES (log for audit + retry)
// ─────────────────────────────────────────────────────────────────────────────

enum WhatsAppStatus {
  queued
  sent
  delivered
  failed
  skipped
}

model WhatsAppMessage {
  id           String        @id @default(cuid())
  leadId       String?
  userId       String?
  toNumber     String
  templateName String
  payload      Json          // template variables
  status       WhatsAppStatus @default(queued)
  providerRef  String?       // provider message ID for tracking
  errorMessage String?
  retryCount   Int           @default(0)
  sentAt       DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([leadId])
  @@index([status])
  @@index([toNumber])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTOMATION JOBS (event-driven async tasks)
// ─────────────────────────────────────────────────────────────────────────────

enum AutomationJobStatus {
  pending
  processing
  done
  failed
  skipped
}

model AutomationJob {
  id          String             @id @default(cuid())
  eventName   String             // e.g. "payment_success", "assessment_completed"
  payload     Json               // event payload
  status      AutomationJobStatus @default(pending)
  attempts    Int                @default(0)
  maxAttempts Int                @default(3)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([eventName])
  @@index([status])
  @@index([createdAt])
  @@map("automation_jobs")
}

// ─────────────────────────────────────────────────────────────────────────────
// ANALYTICS EVENTS (lightweight funnel tracking)
// ─────────────────────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(cuid())
  event      String   // e.g. "lead_created", "premium_cta_clicked"
  userId     String?
  leadId     String?
  sessionId  String?
  source     String?  // utm_source or lead source
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@index([leadId])
  @@index([createdAt])
  @@map("analytics_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// CCL BUSINESS LAYER — Phase 4
// ─────────────────────────────────────────────────────────────────────────────

/// Joining links created by a CCL to onboard new counsellor candidates.
/// Each link carries a unique code; clicking it starts the ₹12,000 joining flow
/// and attributes the sale back to the originating CCL.
model CclJoiningLink {
  id             String    @id @default(cuid())
  cclUserId      String
  code           String    @unique

  candidateName  String?
  candidateEmail String?
  candidatePhone String?

  feeAmountPaise Int       @default(1200000) // ₹12,000

  // Payment tracking for the candidate's joining payment
  joiningOrderId         String?   @unique  // Razorpay order ID created for this link
  joiningPaymentId       String?            // Razorpay payment ID after capture
  joiningPaymentStatus   String    @default("pending") // "pending" | "initiated" | "captured" | "failed"
  joiningNetAmountPaise  Int?               // Effective amount after discount (stored at order creation)

  isUsed         Boolean   @default(false)
  usedAt         DateTime?
  expiresAt      DateTime?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  cclUser        User               @relation("CclJoiningLinks", fields: [cclUserId], references: [id], onDelete: Cascade)
  attributedSale CclAttributedSale?

  @@index([cclUserId])
  @@index([code])
  @@index([joiningOrderId])
  @@map("ccl_joining_links")
}

/// Ledger record for every sale attributed to a CCL — whether via joining link
/// or referral code. Commission is always 10% of netAmountPaise.
model CclAttributedSale {
  id                  String   @id @default(cuid())
  cclUserId           String
  joiningLinkId       String?  @unique   // populated for joining-link sales
  paymentId           String?  @unique   // FK to platform Payment row, if available
  saleType            String             // "joining" | "referral" | "other"

  grossAmountPaise    Int
  discountAmountPaise Int      @default(0)
  netAmountPaise      Int
  commissionPaise     Int                // 10% of netAmountPaise

  status              String   @default("pending") // "pending" | "confirmed" | "refunded"

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  cclUser      User            @relation("CclAttributedSales", fields: [cclUserId], references: [id])
  joiningLink  CclJoiningLink? @relation(fields: [joiningLinkId], references: [id])
  commission   CclCommission?

  @@index([cclUserId])
  @@index([status])
  @@map("ccl_attributed_sales")
}

/// One commission record per attributed sale. Aggregated into a CclPayout when
/// the weekly Thursday transfer is processed.
model CclCommission {
  id               String   @id @default(cuid())
  cclUserId        String
  attributedSaleId String   @unique
  amountPaise      Int

  status           String   @default("pending") // "pending" | "paid" | "cancelled"
  payoutId         String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  cclUser        User              @relation("CclCommissions", fields: [cclUserId], references: [id])
  attributedSale CclAttributedSale @relation(fields: [attributedSaleId], references: [id])
  payout         CclPayout?        @relation(fields: [payoutId], references: [id])

  @@index([cclUserId])
  @@index([status])
  @@map("ccl_commissions")
}

/// Weekly payout record — one per CCL per Thursday cycle. Groups commissions.
model CclPayout {
  id           String    @id @default(cuid())
  cclUserId    String
  amountPaise  Int
  status       String    @default("pending") // "pending" | "processing" | "paid" | "failed"
  scheduledFor DateTime                        // always a Thursday
  processedAt  DateTime?
  reference    String?   // bank transfer reference once paid
  notes        String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  cclUser     User            @relation("CclPayouts", fields: [cclUserId], references: [id])
  commissions CclCommission[]

  @@index([cclUserId])
  @@index([status])
  @@index([scheduledFor])
  @@map("ccl_payouts")
}

/// Optional per-CCL discount configuration. Cap enforced at 20% in the backend.
model CclDiscount {
  id          String   @id @default(cuid())
  cclUserId   String   @unique
  discountPct Float    @default(0)   // 0–20
  isActive    Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  cclUser User @relation("CclDiscount", fields: [cclUserId], references: [id], onDelete: Cascade)

  @@map("ccl_discounts")
}

/// Training content items visible to CCL (videos, books, documents).
/// Managed by Admin; read-only for CCL.
/// targetRole controls which role sees this content: 'CCL', 'CC', or 'ALL'.
model CclTrainingContent {
  id           String   @id @default(cuid())
  title        String
  type         String              // "video" | "book" | "document"
  url          String?
  description  String?
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  targetRole   String   @default("CCL") // "CCL" | "CC" | "ALL"

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ccl_training_content")
}

// ─────────────────────────────────────────────────────────────────────────────
// CC BUSINESS LAYER — Phase 5
// ─────────────────────────────────────────────────────────────────────────────

/// Test links created by a CC to send to students/parents.
/// Payment goes to platform; successful payment creates CcAttributedSale + CcCommission.
model CcTestLink {
  id                   String    @id @default(cuid())
  ccUserId             String
  code                 String    @unique
  planType             String    @default("standard")   // "499plan" | "standard"
  candidateName        String?
  candidateEmail       String?
  candidatePhone       String?
  feeAmountPaise       Int       @default(49900)        // ₹499
  isUsed               Boolean   @default(false)
  usedAt               DateTime?
  expiresAt            DateTime?
  testOrderId          String?   @unique
  testPaymentId        String?
  testPaymentStatus    String    @default("pending")
  testNetAmountPaise   Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  ccUser               User              @relation("CcTestLinks", fields: [ccUserId], references: [id], onDelete: Cascade)
  attributedSales      CcAttributedSale[]

  @@index([ccUserId])
  @@index([testOrderId])
  @@map("cc_test_links")
}

/// Ledger record for every sale attributed to a CC via test link. Commission is 70% of netAmountPaise.
model CcAttributedSale {
  id                   String    @id @default(cuid())
  ccUserId             String
  testLinkId           String?   @unique
  paymentId            String    @unique
  saleType             String
  grossAmountPaise     Int
  discountAmountPaise  Int       @default(0)
  netAmountPaise       Int
  commissionPaise      Int
  status               String    @default("confirmed")
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  ccUser               User        @relation("CcAttributedSales", fields: [ccUserId], references: [id], onDelete: Restrict)
  testLink             CcTestLink? @relation(fields: [testLinkId], references: [id], onDelete: SetNull)
  commission           CcCommission?

  @@index([ccUserId])
  @@index([status])
  @@map("cc_attributed_sales")
}

/// One commission record per attributed CC sale. Aggregated into CcPayout on Thursday.
model CcCommission {
  id               String    @id @default(cuid())
  ccUserId         String
  attributedSaleId String    @unique
  amountPaise      Int
  status           String    @default("pending")   // pending | in_payout | paid | cancelled
  payoutId         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ccUser           User             @relation("CcCommissions", fields: [ccUserId], references: [id], onDelete: Restrict)
  attributedSale   CcAttributedSale @relation(fields: [attributedSaleId], references: [id])
  payout           CcPayout?        @relation(fields: [payoutId], references: [id])

  @@index([ccUserId])
  @@index([status])
  @@map("cc_commissions")
}

/// Weekly payout record — one per CC per Thursday cycle. Groups commissions.
model CcPayout {
  id           String    @id @default(cuid())
  ccUserId     String
  amountPaise  Int
  status       String    @default("pending")
  scheduledFor DateTime
  processedAt  DateTime?
  reference    String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ccUser       User           @relation("CcPayouts", fields: [ccUserId], references: [id], onDelete: Restrict)
  commissions  CcCommission[]

  @@index([ccUserId])
  @@index([status])
  @@index([scheduledFor])
  @@map("cc_payouts")
}

/// Optional per-CC discount configuration. Cap enforced in backend (plan-aware).
model CcDiscount {
  id          String   @id @default(cuid())
  ccUserId    String   @unique
  discountPct Float    @default(0)
  planType    String   @default("standard")   // "499plan" | "standard" — determines max cap
  isActive    Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  ccUser      User @relation("CcDiscount", fields: [ccUserId], references: [id], onDelete: Cascade)

  @@map("cc_discounts")
}
